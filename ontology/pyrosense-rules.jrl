# ============================================================
#  PyroSense Jena Kural Dosyası  — v2.0
#  Orman tipine göre diferansiye edilmiş yangın risk kuralları
#  + Topoloji bazlı risk yükseltme kuralları
#
#  Toplam: 60 orman tipi kuralı + 3 topoloji kuralı = 63 kural
#
#  DEĞİŞİKLİK NOTLARI (v1 → v2):
#    - OWL-JRL yapısal hizalaması düzeltildi:
#        smokePPM → smokePpm, co2PPM → co2Ppm
#    - CO2 mutlak eşikleri 430-560 → 750-1000 ppm aralığına çekildi
#        (NDIR sensör doğruluğu ±200 ppm; atmosferik baz ~422 ppm)
#    - RedPine eşikleri düzeltildi: T>36→T>32, RH<20→RH<30
#        (Kızılçam Türkiye'nin en yangın duyarlı türü — önceki eşikler
#         çok geçti, yanlış yönde kalibre edilmişti)
#    - Shrubland eşikleri düzeltildi: T>34→T>30, smoke>80→smoke>60
#        (Maki Akdeniz kıyısında RedPine'dan bile agresif ön-alarm gerektirir)
#    - OrientalSpruce eşikleri düzeltildi: T>26→T>33, smoke>110→smoke>140
#        (Doğu Karadeniz'in en nemli ormanı — önceki eşikler çok erken
#         tetikleniyordu, sis/nem ile FP üretiyordu)
#    - ScotsPine eşikleri hafif düzeltildi: T>26→T>28, smoke>70→smoke>80
#    - FlameDetected: birincil erken alarm değil, teyit/yükseltme kuralı
#        olarak yorumlanmalı (duman genellikle alevden önce görünür)
#
#  Orman Tipleri (12):
#    RedPine, BlackPine, ScotsPine, TaurusCedar, SilverFir,
#    OrientalSpruce, Oak, OrientalBeech, Alder, Shrubland,
#    Juniper, Mixed
#
#  Kural Kategorileri (5):
#    1. HighDroughtRisk   — yüksek sıcaklık + düşük nem
#    2. SmokeAlarm        — duman eşiği aşıldı
#    3. SpreadRisk        — yüksek rüzgar + sıcaklık kombinasyonu
#    4. EarlySignal       — CO2 + duman kombinasyonu (yüksek kaliteli sensör şart)
#    5. FlameDetected     — alev dedektörü tetiklendi (teyit/yükseltme)
#
#  Topoloji Kuralları (3):
#    Valley_WindAmplification
#    Ridge_WindExposure
#    Slope_FireSpread
# ============================================================

# ------------------------------------------------------------
# 1. RED PINE — Kızılçam (Pinus brutia)
# En yüksek yangın riski — Akdeniz-Ege kıyı kuşağı, reçineli
# Türkiye'de yangından en fazla etkilenen tür
# Eşikler: en düşük (en hassas) — T>32, RH<30
# ------------------------------------------------------------

[RedPine_HighDroughtRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "RedPine")
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?temp, 32)
  lessThan(?hum, 30)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_DROUGHT_RISK")
]

[RedPine_SmokeAlarm:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "RedPine")
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?smoke, 75)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SMOKE_ALARM")
]

[RedPine_SpreadRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "RedPine")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 7)
  greaterThan(?temp, 30)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_SPREAD_RISK")
]

[RedPine_EarlySignal:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "RedPine")
  (?reading <http://pyrosense.io/ontology#co2Ppm> ?co2)
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?co2, 800)
  greaterThan(?smoke, 40)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "EARLY_FIRE_SIGNAL")
]

[RedPine_FlameDetected:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "RedPine")
  (?reading <http://pyrosense.io/ontology#flameDetected> "true"^^xsd:boolean)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "FLAME_DETECTED")
]


