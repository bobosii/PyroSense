# ------------------------------------------------------------
# 6. ORIENTAL SPRUCE — Doğu Ladini (Picea orientalis)
# Düşük-orta risk — Doğu Karadeniz (Ordu→Artvin), en nemli orman
# Sis/nem FP riski yüksek; eşikler konservatif tutulmuştur
# Önceki T>26 çok erken — düzeltildi: T>33
# ------------------------------------------------------------

[OrientalSpruce_HighDroughtRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalSpruce")
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?temp, 33)
  lessThan(?hum, 22)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_DROUGHT_RISK")
]

[OrientalSpruce_SmokeAlarm:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalSpruce")
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?smoke, 140)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SMOKE_ALARM")
]

[OrientalSpruce_SpreadRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalSpruce")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 10)
  greaterThan(?temp, 28)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_SPREAD_RISK")
]

[OrientalSpruce_EarlySignal:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalSpruce")
  (?reading <http://pyrosense.io/ontology#co2Ppm> ?co2)
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?co2, 950)
  greaterThan(?smoke, 75)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "EARLY_FIRE_SIGNAL")
]

[OrientalSpruce_FlameDetected:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalSpruce")
  (?reading <http://pyrosense.io/ontology#flameDetected> "true"^^xsd:boolean)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "FLAME_DETECTED")
]


# ------------------------------------------------------------
# 7. OAK — Meşe (Quercus türleri)
# Orta risk — Türkiye geneli yaygın, 200-1500m
# NOT: Meşe Türkiye'de çok heterojen bir gruptur (pırnal, saplı,
# macar meşesi vb.); üretimde EvergreenOak/DeciduousOak olarak
# ayrıştırılması önerilir.
# ------------------------------------------------------------

[Oak_HighDroughtRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Oak")
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?temp, 34)
  lessThan(?hum, 25)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_DROUGHT_RISK")
]

[Oak_SmokeAlarm:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Oak")
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?smoke, 110)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SMOKE_ALARM")
]

[Oak_SpreadRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Oak")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 9)
  greaterThan(?temp, 30)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_SPREAD_RISK")
]

[Oak_EarlySignal:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Oak")
  (?reading <http://pyrosense.io/ontology#co2Ppm> ?co2)
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?co2, 900)
  greaterThan(?smoke, 70)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "EARLY_FIRE_SIGNAL")
]

[Oak_FlameDetected:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Oak")
  (?reading <http://pyrosense.io/ontology#flameDetected> "true"^^xsd:boolean)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "FLAME_DETECTED")
]


# ------------------------------------------------------------
# 8. ORIENTAL BEECH — Kayın (Fagus orientalis)
# Düşük-orta risk — Karadeniz, nemli ve ılıman, 500-1800m
# Yüksek alarm bariyeri doğru; kuraklık anomalisi + yıldırım
# kombinasyonu ile daha anlamlı
# ------------------------------------------------------------

[OrientalBeech_HighDroughtRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalBeech")
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?temp, 35)
  lessThan(?hum, 25)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_DROUGHT_RISK")
]

[OrientalBeech_SmokeAlarm:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalBeech")
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?smoke, 120)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SMOKE_ALARM")
]

[OrientalBeech_SpreadRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalBeech")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 10)
  greaterThan(?temp, 32)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_SPREAD_RISK")
]

[OrientalBeech_EarlySignal:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalBeech")
  (?reading <http://pyrosense.io/ontology#co2Ppm> ?co2)
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?co2, 950)
  greaterThan(?smoke, 80)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "EARLY_FIRE_SIGNAL")
]

[OrientalBeech_FlameDetected:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "OrientalBeech")
  (?reading <http://pyrosense.io/ontology#flameDetected> "true"^^xsd:boolean)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "FLAME_DETECTED")
]


# ------------------------------------------------------------
# 9. ALDER — Kızılağaç (Alnus türleri)
# Düşük risk — riparian (dere/ırmak kenarı), su etkisi
# Trakya, Marmara, Batı ve Doğu Karadeniz dere içleri
# En yüksek alarm bariyeri — komşu alan yangını için kenar etkisi
# kuralı daha anlamlı olur
# ------------------------------------------------------------

[Alder_HighDroughtRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Alder")
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?temp, 36)
  lessThan(?hum, 20)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_DROUGHT_RISK")
]

[Alder_SmokeAlarm:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Alder")
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?smoke, 130)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SMOKE_ALARM")
]

[Alder_SpreadRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Alder")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 11)
  greaterThan(?temp, 33)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_SPREAD_RISK")
]

[Alder_EarlySignal:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Alder")
  (?reading <http://pyrosense.io/ontology#co2Ppm> ?co2)
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?co2, 1000)
  greaterThan(?smoke, 85)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "EARLY_FIRE_SIGNAL")
]

[Alder_FlameDetected:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Alder")
  (?reading <http://pyrosense.io/ontology#flameDetected> "true"^^xsd:boolean)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "FLAME_DETECTED")
]


# ------------------------------------------------------------
# 10. SHRUBLAND — Maki (Akdeniz makisi / Pseudomaquis)
# En agresif ön-alarm sınıfı — Akdeniz kıyısı, çok hızlı yayılım
# Toz/sis/pollen FP'lerine karşı çoklu doğrulama önerilir
# RedPine'dan daha düşük eşikler: T>30, smoke>60
# ------------------------------------------------------------

[Shrubland_HighDroughtRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Shrubland")
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?temp, 30)
  lessThan(?hum, 25)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_DROUGHT_RISK")
]

[Shrubland_SmokeAlarm:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Shrubland")
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?smoke, 60)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SMOKE_ALARM")
]

[Shrubland_SpreadRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Shrubland")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 6)
  greaterThan(?temp, 28)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_SPREAD_RISK")
]

[Shrubland_EarlySignal:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Shrubland")
  (?reading <http://pyrosense.io/ontology#co2Ppm> ?co2)
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?co2, 750)
  greaterThan(?smoke, 30)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "EARLY_FIRE_SIGNAL")
]

[Shrubland_FlameDetected:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Shrubland")
  (?reading <http://pyrosense.io/ontology#flameDetected> "true"^^xsd:boolean)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "FLAME_DETECTED")
]


# ------------------------------------------------------------
# 11. JUNIPER — Ardıç (Juniperus türleri)
# Orta-yüksek risk — kuru iç Anadolu, yarı-kurak, açık yapılı
# yamaç sistemleri; insan erişimi ve topografya eklenmeli
# ------------------------------------------------------------

[Juniper_HighDroughtRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Juniper")
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?temp, 30)
  lessThan(?hum, 28)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_DROUGHT_RISK")
]

[Juniper_SmokeAlarm:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Juniper")
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?smoke, 80)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SMOKE_ALARM")
]

[Juniper_SpreadRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Juniper")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 7)
  greaterThan(?temp, 27)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_SPREAD_RISK")
]

[Juniper_EarlySignal:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Juniper")
  (?reading <http://pyrosense.io/ontology#co2Ppm> ?co2)
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?co2, 880)
  greaterThan(?smoke, 55)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "EARLY_FIRE_SIGNAL")
]

[Juniper_FlameDetected:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Juniper")
  (?reading <http://pyrosense.io/ontology#flameDetected> "true"^^xsd:boolean)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "FLAME_DETECTED")
]


# ------------------------------------------------------------
# 12. MIXED — Karma Orman
# Orta risk — karma tür bileşimi, ortalama eşikler
# NOT: Bu etiket ontolojik olarak yetersizdir. Üretimde
# dominantSpecies, secondarySpecies, crownClosure ve
# developmentClass alanları zorunlu olmalıdır.
# ------------------------------------------------------------

[Mixed_HighDroughtRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Mixed")
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?temp, 31)
  lessThan(?hum, 30)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_DROUGHT_RISK")
]

[Mixed_SmokeAlarm:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Mixed")
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?smoke, 90)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SMOKE_ALARM")
]

[Mixed_SpreadRisk:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Mixed")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 8)
  greaterThan(?temp, 28)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "HIGH_SPREAD_RISK")
]

[Mixed_EarlySignal:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Mixed")
  (?reading <http://pyrosense.io/ontology#co2Ppm> ?co2)
  (?reading <http://pyrosense.io/ontology#smokePpm> ?smoke)
  greaterThan(?co2, 880)
  greaterThan(?smoke, 60)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "EARLY_FIRE_SIGNAL")
]

[Mixed_FlameDetected:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#forestType> "Mixed")
  (?reading <http://pyrosense.io/ontology#flameDetected> "true"^^xsd:boolean)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "FLAME_DETECTED")
]


# ============================================================
# TOPOGRAFİK ETKİ KURALLARI
# Orman tipinden bağımsız — topoloji bazlı risk yükseltme
# ============================================================

# Vadi + yüksek rüzgar + sıcaklık → yayılma riski
# Vadi topografyası rüzgarı kanalize eder (blow-up fire riski)
[Valley_WindAmplification:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#topology> "Valley")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  greaterThan(?wind, 6)
  greaterThan(?temp, 25)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "VALLEY_WIND_AMPLIFICATION")
]

# Sırt + yüksek rüzgar → erken uyarı kritik
# Sırt hattında rüzgar açık akar; rüzgar yönü eklenmeli
[Ridge_WindExposure:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#topology> "Ridge")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  greaterThan(?wind, 8)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "RIDGE_WIND_EXPOSURE")
]

# Yamaç + kuru + rüzgarlı → erken yayılım uyarısı
# Alevler yamaçta aşağıdan yukarı çok hızlı tırmanır
# Güney bakılı ve dik yamaçlar (slope_deg, aspect_class) eklenmeli
[Slope_FireSpread:
  (?reading rdf:type <http://pyrosense.io/ontology#SensorReading>)
  (?reading <http://www.w3.org/ns/ssn/isObservedBy> ?node)
  (?node <http://pyrosense.io/ontology#topology> "Slope")
  (?reading <http://pyrosense.io/ontology#windSpeedMs> ?wind)
  (?reading <http://pyrosense.io/ontology#temperature> ?temp)
  (?reading <http://pyrosense.io/ontology#humidity> ?hum)
  greaterThan(?wind, 5)
  greaterThan(?temp, 30)
  lessThan(?hum, 30)
  ->
  (?reading <http://pyrosense.io/ontology#riskFlag> "SLOPE_FIRE_SPREAD_CRITICAL")
]
