@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrlb:<http://www.w3.org/2003/11/swrlb#> .
@prefix pyro: <http://pyrosense.io/ontology#> .

# ============================================================
#  PyroSense Çekirdek Ontoloji — OWL 2 / Turtle Formatı
#  Versiyon: 1.0 | Tarih: 2026
#
#  İçerik:
#    - Çevre Sınıfları (ForestType, Topology, DroughtIndex)
#    - Sensör Sınıfları (SensorNode, SensorReading)
#    - Meteoroloji Sınıfları (WeatherObservation, WindClass)
#    - Risk Sınıfları (RiskLevel, FireAlarm)
#    - SWRL Kuralları (5 temel kural)
# ============================================================

<http://pyrosense.io/ontology>
    a owl:Ontology ;
    rdfs:label "PyroSense Orman Yangını Erken Uyarı Ontolojisi" ;
    rdfs:comment "OWL 2 tabanlı çok katmanlı yangın riski ontolojisi" ;
    owl:versionInfo "1.0" .

# ============================================================
# BÖLÜM 1: ÇEVRE ONTOLOJİSİ
# ============================================================

# --- Orman Tipi ---
pyro:ForestType a owl:Class ;
    rdfs:label "Orman Tipi" .

pyro:ConiferForest a owl:Class ;
    rdfs:subClassOf pyro:ForestType ;
    rdfs:label "İbreli Orman (Çam)" ;
    rdfs:comment "En yüksek yangın riski. Reçineli yapı, düşük nem tutma." .

pyro:DeciduousForest a owl:Class ;
    rdfs:subClassOf pyro:ForestType ;
    rdfs:label "Yapraklı Orman (Kayın)" ;
    rdfs:comment "Daha düşük yangın riski. Daha yüksek nem tutma kapasitesi." .

pyro:MixedForest a owl:Class ;
    rdfs:subClassOf pyro:ForestType ;
    rdfs:label "Karma Orman" .

pyro:ShrubLand a owl:Class ;
    rdfs:subClassOf pyro:ForestType ;
    rdfs:label "Maki / Çalılık" ;
    rdfs:comment "Kuru dönemde yüksek risk." .

# --- Topografya ---
pyro:Topology a owl:Class ;
    rdfs:label "Topografya" .

pyro:ValleyTopology a owl:Class ;
    rdfs:subClassOf pyro:Topology ;
    rdfs:label "Vadi" ;
    rdfs:comment "Rüzgar kanallaşma etkisi — yangın yayılım hızı artar." .

pyro:SlopeTopology a owl:Class ;
    rdfs:subClassOf pyro:Topology ;
    rdfs:label "Yamaç" .

pyro:RidgeTopology a owl:Class ;
    rdfs:subClassOf pyro:Topology ;
    rdfs:label "Sırt" .

pyro:PlainTopology a owl:Class ;
    rdfs:subClassOf pyro:Topology ;
    rdfs:label "Düzlük" .

# --- Kuraklık İndeksi ---
pyro:DroughtIndex a owl:Class ;
    rdfs:label "Kuraklık İndeksi" ;
    rdfs:comment "Son 30 günlük yağışa göre hesaplanır (Open-Meteo)" .

pyro:NormalMoisture a owl:Class ;
    rdfs:subClassOf pyro:DroughtIndex ;
    rdfs:label "Normal Nem" ;
    rdfs:comment "Yağış >= 10mm/30gün" .

pyro:ModerateDrought a owl:Class ;
    rdfs:subClassOf pyro:DroughtIndex ;
    rdfs:label "Orta Kuraklık" ;
    rdfs:comment "Yağış 2-10mm/30gün" .

pyro:ExtremeDrought a owl:Class ;
    rdfs:subClassOf pyro:DroughtIndex ;
    rdfs:label "Aşırı Kuraklık" ;
    rdfs:comment "Yağış < 2mm/30gün" .

# --- Bölge (Izgarası) ---
pyro:Zone a owl:Class ;
    rdfs:label "İzleme Bölgesi" .

pyro:hasForestType a owl:ObjectProperty ;
    rdfs:domain pyro:Zone ;
    rdfs:range pyro:ForestType ;
    rdfs:label "orman tipi" .

pyro:hasTopology a owl:ObjectProperty ;
    rdfs:domain pyro:Zone ;
    rdfs:range pyro:Topology ;
    rdfs:label "topografya" .

pyro:hasDroughtIndex a owl:ObjectProperty ;
    rdfs:domain pyro:Zone ;
    rdfs:range pyro:DroughtIndex ;
    rdfs:label "kuraklık indeksi" .

pyro:latitude a owl:DatatypeProperty ;
    rdfs:domain pyro:Zone ;
    rdfs:range xsd:double ;
    rdfs:label "Enlem (WGS84)" ;
    rdfs:comment "Bölge merkez koordinatı — bölgeler arası rüzgar yayılım hesabında kullanılır." .

pyro:longitude a owl:DatatypeProperty ;
    rdfs:domain pyro:Zone ;
    rdfs:range xsd:double ;
    rdfs:label "Boylam (WGS84)" .

pyro:zoneId a owl:DatatypeProperty ;
    rdfs:domain pyro:Zone ;
    rdfs:range xsd:string ;
    rdfs:label "Bölge Kimliği" ;
    rdfs:comment "Simülatör ve MQTT topic'teki zone_id ile eşleşmeli." .

# ============================================================
# BÖLÜM 1b: BÖLGE NAMED INDIVIDUALS — 12 Türkiye Orman Tipi
# ============================================================

pyro:zone_redpine a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_redpine" ;
    pyro:latitude   "37.2151"^^xsd:double ;
    pyro:longitude  "28.3627"^^xsd:double ;
    pyro:hasForestType pyro:ConiferForest ;
    pyro:hasTopology   pyro:SlopeTopology ;
    rdfs:label      "Kızılçam — Muğla/Menteşe" ;
    rdfs:comment    "Akdeniz kıyısı kızılçam ormanı. Yüksek yangın riski bölgesi." .

pyro:zone_blackpine a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_blackpine" ;
    pyro:latitude   "41.3780"^^xsd:double ;
    pyro:longitude  "33.7743"^^xsd:double ;
    pyro:hasForestType pyro:ConiferForest ;
    pyro:hasTopology   pyro:RidgeTopology ;
    rdfs:label      "Karaçam — Kastamonu" ;
    rdfs:comment    "İç Anadolu–Karadeniz geçiş kuşağı karaçam ormanı." .

pyro:zone_scotspine a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_scotspine" ;
    pyro:latitude   "40.3334"^^xsd:double ;
    pyro:longitude  "42.5905"^^xsd:double ;
    pyro:hasForestType pyro:ConiferForest ;
    pyro:hasTopology   pyro:RidgeTopology ;
    rdfs:label      "Sarıçam — Sarıkamış/Kars" ;
    rdfs:comment    "Kuzeydoğu yüksek plato sarıçam ormanı." .

pyro:zone_tauruscedar a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_tauruscedar" ;
    pyro:latitude   "37.1000"^^xsd:double ;
    pyro:longitude  "34.6000"^^xsd:double ;
    pyro:hasForestType pyro:ConiferForest ;
    pyro:hasTopology   pyro:SlopeTopology ;
    rdfs:label      "Toros Sediri — Toros Dağları/Mersin" ;
    rdfs:comment    "Toros Dağları endemik sedir ormanı." .

pyro:zone_silverfir a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_silverfir" ;
    pyro:latitude   "40.7350"^^xsd:double ;
    pyro:longitude  "31.6000"^^xsd:double ;
    pyro:hasForestType pyro:ConiferForest ;
    pyro:hasTopology   pyro:SlopeTopology ;
    rdfs:label      "Göknar — Bolu/Abant" ;
    rdfs:comment    "Karadeniz arka sırası göknar ormanı." .

pyro:zone_orientalspruce a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_orientalspruce" ;
    pyro:latitude   "41.0500"^^xsd:double ;
    pyro:longitude  "40.5000"^^xsd:double ;
    pyro:hasForestType pyro:ConiferForest ;
    pyro:hasTopology   pyro:SlopeTopology ;
    rdfs:label      "Doğu Ladini — Rize/Artvin" ;
    rdfs:comment    "Doğu Karadeniz yağışlı kuşak ladin ormanı." .

pyro:zone_oak a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_oak" ;
    pyro:latitude   "40.4697"^^xsd:double ;
    pyro:longitude  "32.6558"^^xsd:double ;
    pyro:hasForestType pyro:DeciduousForest ;
    pyro:hasTopology   pyro:ValleyTopology ;
    rdfs:label      "Meşe — Kızılcahamam/Ankara" ;
    rdfs:comment    "İç Anadolu–Karadeniz geçiş kuşağı meşe ormanı." .

pyro:zone_orientalbeech a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_orientalbeech" ;
    pyro:latitude   "41.2000"^^xsd:double ;
    pyro:longitude  "32.6000"^^xsd:double ;
    pyro:hasForestType pyro:DeciduousForest ;
    pyro:hasTopology   pyro:SlopeTopology ;
    rdfs:label      "Doğu Kayını — Karabük/Yenice" ;
    rdfs:comment    "Batı Karadeniz kayın ormanı." .

pyro:zone_alder a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_alder" ;
    pyro:latitude   "36.3000"^^xsd:double ;
    pyro:longitude  "33.9833"^^xsd:double ;
    pyro:hasForestType pyro:DeciduousForest ;
    pyro:hasTopology   pyro:ValleyTopology ;
    rdfs:label      "Kızılağaç — Göksu Deltası/Mersin" ;
    rdfs:comment    "Sulak alan kenarı kızılağaç ormanı." .

pyro:zone_shrubland a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_shrubland" ;
    pyro:latitude   "36.8841"^^xsd:double ;
    pyro:longitude  "30.7056"^^xsd:double ;
    pyro:hasForestType pyro:ShrubLand ;
    pyro:hasTopology   pyro:SlopeTopology ;
    rdfs:label      "Maki — Antalya Kıyısı" ;
    rdfs:comment    "Akdeniz kuru maki, yaz kuraklığında yüksek yangın riski." .

pyro:zone_juniper a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_juniper" ;
    pyro:latitude   "37.6750"^^xsd:double ;
    pyro:longitude  "31.7250"^^xsd:double ;
    pyro:hasForestType pyro:ConiferForest ;
    pyro:hasTopology   pyro:PlainTopology ;
    rdfs:label      "Ardıç — Beyşehir/Konya" ;
    rdfs:comment    "İç Anadolu yarı-kurak ardıç ormanı." .

pyro:zone_mixed a owl:NamedIndividual, pyro:Zone ;
    pyro:zoneId     "zone_mixed" ;
    pyro:latitude   "41.1944"^^xsd:double ;
    pyro:longitude  "28.9514"^^xsd:double ;
    pyro:hasForestType pyro:MixedForest ;
    pyro:hasTopology   pyro:ValleyTopology ;
    rdfs:label      "Karma Orman — Belgrad Ormanı/İstanbul" ;
    rdfs:comment    "Karma orman, kentsel-periferik sınır bölgesi." .

# ============================================================
# BÖLÜM 2: SENSÖR ONTOLOJİSİ (W3C SSN'den türetilmiş)
# ============================================================

pyro:SensorNode a owl:Class ;
    rdfs:label "Sensör Düğümü" ;
    rdfs:comment "Fiziksel veya simüle edilmiş IoT sensör düğümü" .

pyro:SensorReading a owl:Class ;
    rdfs:label "Sensör Okuması" .

# Sayısal özellikler — SensorReading üzerinde
# NOT: Özellik adları rdfConverter.ts ve pyrosense-rules.jrl ile birebir hizalıdır.
pyro:temperature      a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:double ; rdfs:label "Sıcaklık (°C)" .
pyro:humidity         a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:double ; rdfs:label "Nem (%)" .
pyro:smokePpm         a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:double ;
    rdfs:label "Duman Yoğunluğu (simüle ppm)" ;
    rdfs:comment "Üretimde PM2.5/PM10 µg/m³ (pm25UgM3, pm10UgM3) ile değiştirilmeli. Parçacık sensörleri hacimsel ppm değil kütlesel yoğunluk verir." .
pyro:uvIndex          a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:double ; rdfs:label "UV İndeksi" .
pyro:windSpeedMs      a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:double ; rdfs:label "Rüzgar Hızı (m/s)" .
pyro:windDirDeg       a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:integer ; rdfs:label "Rüzgar Yönü (derece)" .
pyro:flameDetected    a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:boolean ;
    rdfs:label "Alev Tespiti" ;
    rdfs:comment "Doğrulama/teyit kuralı olarak kullanılmalı. Duman genellikle alevden önce görünür; FlameDetected erken uyarı değil kritik yükseltme sinyalidir." .
pyro:co2Ppm           a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:double ;
    rdfs:label "CO2 (ppm)" ;
    rdfs:comment "NDIR sensör doğruluğu ±200 ppm bandındadır. 2026 atmosferik baz ~422 ppm. Yalnızca yüksek kaliteli sensör mevcutsa ve eşik >800 ppm ise anlamlıdır; düşük maliyetli sensörlerde yardımcı değişken olarak kullan." .

# Risk çıktısı — SensorReading üzerinde (Jena rule motoru bu özelliğe yazar)
pyro:riskFlag         a owl:DatatypeProperty ; rdfs:domain pyro:SensorReading ; rdfs:range xsd:string ;
    rdfs:label "Risk Bayrağı" ;
    rdfs:comment "Jena kural motorunun tetiklenen kural sonucunu yazdığı özellik. Değerler: HIGH_DROUGHT_RISK, SMOKE_ALARM, HIGH_SPREAD_RISK, EARLY_FIRE_SIGNAL, FLAME_DETECTED, VALLEY_WIND_AMPLIFICATION, RIDGE_WIND_EXPOSURE, SLOPE_FIRE_SPREAD_CRITICAL" .

# SensorNode üzerindeki bağlamsal özellikler
# NOT: rdfConverter.ts bu değerleri SensorNode üzerine string literal olarak yazar.
# OWL Zone.hasForestType ve Zone.hasTopology nesne özellikleri ile kavramsal model tutulur;
# ancak JRL kural motoru için SensorNode üzerindeki string özellikler kullanılır.
pyro:forestType       a owl:DatatypeProperty ; rdfs:domain pyro:SensorNode ; rdfs:range xsd:string ;
    rdfs:label "Orman Tipi (string)" ;
    rdfs:comment "JRL kural eşleştirmesi için string literal. Değerler: RedPine, BlackPine, ScotsPine, TaurusCedar, SilverFir, OrientalSpruce, Oak, OrientalBeech, Alder, Shrubland, Juniper, Mixed" .
pyro:topology         a owl:DatatypeProperty ; rdfs:domain pyro:SensorNode ; rdfs:range xsd:string ;
    rdfs:label "Topografya (string)" ;
    rdfs:comment "JRL kural eşleştirmesi için string literal. Değerler: Slope, Valley, Ridge, Plain" .
pyro:droughtClass     a owl:DatatypeProperty ; rdfs:domain pyro:SensorNode ; rdfs:range xsd:string ;
    rdfs:label "Kuraklık Sınıfı (string)" ;
    rdfs:comment "Open-Meteo'dan gelen kuraklık sınıfı. Değerler: NormalMoisture, ModerateDrought, ExtremeDrought. SPARQL sorguları bu değeri okuyarak eşik çarpanını hesaplar." .

# İlişkiler
# NOT: rdfConverter.ts SensorReading → SensorNode yönünde ssn:isObservedBy kullanır.
# hasReading kavramsal modelde (Zone/OWL) tutulur; operasyonel veri akışı ssn:isObservedBy üzerinden çalışır.
pyro:hasReading a owl:ObjectProperty ;
    rdfs:domain pyro:SensorNode ;
    rdfs:range pyro:SensorReading ;
    owl:inverseOf <http://www.w3.org/ns/ssn/isObservedBy> .

pyro:locatedInZone a owl:ObjectProperty ;
    rdfs:domain pyro:SensorNode ;
    rdfs:range pyro:Zone .

# ============================================================
# BÖLÜM 3: METEOROLOJİ ONTOLOJİSİ
# ============================================================

pyro:WeatherObservation a owl:Class ;
    rdfs:label "Hava Durumu Gözlemi" ;
    rdfs:comment "Open-Meteo API'den gelen meteoroloji verisi" .

pyro:WindClass a owl:Class ;
    rdfs:label "Rüzgar Sınıfı" .

pyro:CalmWind    a owl:Class ; rdfs:subClassOf pyro:WindClass ; rdfs:label "Sakin (< 2 m/s)" .
pyro:LightWind   a owl:Class ; rdfs:subClassOf pyro:WindClass ; rdfs:label "Hafif (2-5 m/s)" .
pyro:ModerateWind a owl:Class ; rdfs:subClassOf pyro:WindClass ; rdfs:label "Orta (5-8 m/s)" .
pyro:StrongWind  a owl:Class ; rdfs:subClassOf pyro:WindClass ; rdfs:label "Kuvvetli (> 8 m/s)" .

# ============================================================
# BÖLÜM 4: RİSK ONTOLOJİSİ
# ============================================================

pyro:RiskLevel a owl:Class ;
    rdfs:label "Risk Seviyesi" .

pyro:NegligibleRisk a owl:Class ; rdfs:subClassOf pyro:RiskLevel ; rdfs:label "Önemsiz (0-19)" .
pyro:LowRisk        a owl:Class ; rdfs:subClassOf pyro:RiskLevel ; rdfs:label "Düşük (20-39)" .
pyro:ModerateRisk   a owl:Class ; rdfs:subClassOf pyro:RiskLevel ; rdfs:label "Orta (40-59)" .
pyro:HighRisk       a owl:Class ; rdfs:subClassOf pyro:RiskLevel ; rdfs:label "Yüksek (60-79)" .
pyro:ExtremeRisk    a owl:Class ; rdfs:subClassOf pyro:RiskLevel ; rdfs:label "Ekstrem (80-100)" .

pyro:FireAlarm a owl:Class ;
    rdfs:label "Yangın Alarmı" .

pyro:hasRiskLevel a owl:ObjectProperty ;
    rdfs:domain pyro:Zone ;
    rdfs:range pyro:RiskLevel ;
    rdfs:label "risk seviyesi" .

pyro:riskScore a owl:DatatypeProperty ;
    rdfs:domain pyro:Zone ;
    rdfs:range xsd:integer ;
    rdfs:label "Risk Skoru (0-100)" .

# ============================================================
# BÖLÜM 5: KURAL AĞIRLIKLARI (RiskRule Named Individuals)
#
# Tüm kural ağırlıkları burada tanımlanır.
# TypeScript'te WEIGHTS sabiti yoktur; ağırlıklar SPARQL ile bu
# bireylerden okunur. Bir ağırlığı değiştirmek için sadece bu
# dosyayı güncellemek yeterlidir.
# ============================================================

pyro:RiskRule a owl:Class ;
    rdfs:label "Risk Kuralı" ;
    rdfs:comment "Yangın risk çıkarım kuralı. Her örnek bir kural kimliği ve ağırlık taşır." .

pyro:ruleId a owl:DatatypeProperty ;
    rdfs:domain pyro:RiskRule ;
    rdfs:range  xsd:string ;
    rdfs:label  "Kural Kimliği" ;
    rdfs:comment "inferenceService.ts ve mqttConsumer.ts'deki flag isimleriyle eşleşmeli." .

pyro:ruleWeight a owl:DatatypeProperty ;
    rdfs:domain pyro:RiskRule ;
    rdfs:range  xsd:integer ;
    rdfs:label  "Kural Ağırlığı (0-100)" ;
    rdfs:comment "Risk skoruna katkı. Toplam 100'ü aşarsa Math.min(100, ...) ile kesilir." .

# --- Kural Örnekleri ---

pyro:rule_FLAME_DETECTED a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "FLAME_DETECTED" ;
    pyro:ruleWeight "65"^^xsd:integer ;
    rdfs:label      "Alev Tespiti" ;
    rdfs:comment    "Alev sensörü aktif sinyal verdi. En yüksek ağırlık: doğrudan yangın kanıtı." .

pyro:rule_SLOPE_FIRE_SPREAD_CRITICAL a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "SLOPE_FIRE_SPREAD_CRITICAL" ;
    pyro:ruleWeight "30"^^xsd:integer ;
    rdfs:label      "Yamaç Yayılım Kritik" ;
    rdfs:comment    "Yamaç + düşük nem + rüzgar + yüksek sıcaklık kombinasyonu." .

pyro:rule_SMOKE_ALARM a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "SMOKE_ALARM" ;
    pyro:ruleWeight "35"^^xsd:integer ;
    rdfs:label      "Duman Alarmı" ;
    rdfs:comment    "Türe özgü duman eşiği aşıldı." .

pyro:rule_EARLY_FIRE_SIGNAL a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "EARLY_FIRE_SIGNAL" ;
    pyro:ruleWeight "25"^^xsd:integer ;
    rdfs:label      "Erken Yangın Sinyali" ;
    rdfs:comment    "CO₂ + duman kombinasyonu. NDIR sensör gürültüsünü aşan çift koşul." .

pyro:rule_HIGH_SPREAD_RISK a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "HIGH_SPREAD_RISK" ;
    pyro:ruleWeight "20"^^xsd:integer ;
    rdfs:label      "Yüksek Yayılım Riski" ;
    rdfs:comment    "Rüzgar hızı + sıcaklık kombinasyonu yayılım koşullarını sağlıyor." .

pyro:rule_HIGH_DROUGHT_RISK a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "HIGH_DROUGHT_RISK" ;
    pyro:ruleWeight "20"^^xsd:integer ;
    rdfs:label      "Yüksek Kuraklık Riski" ;
    rdfs:comment    "Türe özgü sıcaklık + nem eşiği kombinasyonu." .

pyro:rule_VALLEY_WIND_AMPLIFICATION a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "VALLEY_WIND_AMPLIFICATION" ;
    pyro:ruleWeight "15"^^xsd:integer ;
    rdfs:label      "Vadi Rüzgar Etkisi" ;
    rdfs:comment    "Vadi topolojisinde rüzgar kanallaşması yangın yayılımını hızlandırır." .

pyro:rule_RIDGE_WIND_EXPOSURE a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "RIDGE_WIND_EXPOSURE" ;
    pyro:ruleWeight "10"^^xsd:integer ;
    rdfs:label      "Sırt Rüzgar Açıklığı" ;
    rdfs:comment    "Sırt topolojisinde yüksek rüzgar maruziyeti." .

pyro:rule_DOWNWIND_SPREAD_THREAT a owl:NamedIndividual, pyro:RiskRule ;
    pyro:ruleId     "DOWNWIND_SPREAD_THREAT" ;
    pyro:ruleWeight "25"^^xsd:integer ;
    rdfs:label      "Rüzgar Altı Yayılım Tehdidi" ;
    rdfs:comment    "Komşu bölgede aktif yangın + mevcut bölge rüzgar altı konumunda. Bölgeler arası yayılım riski." .

# ============================================================
# BÖLÜM 6: SWRL KURALLARI
#
# Not: Bu kurallar Apache Jena Fuseki ile çalışmak için
# Jena Rule Language formatında da yazılacak.
# Aşağıdakiler kavramsal SWRL gösterimidir.
# ============================================================

# -----------------------------------------------------------
# KURAL 1 — Ekstrem Risk
# Alev dedektörü tetiklenmiş + duman > 500 PPM + rüzgar > 5 m/s
# → ExtremeFire → müdahale gerekli
# -----------------------------------------------------------
# SensorNode(?n) ∧ hasReading(?n, ?r) ∧ flameDetected(?r, true)
#   ∧ smokePPM(?r, ?s) ∧ swrlb:greaterThan(?s, 500)
#   ∧ windSpeedMs(?r, ?w) ∧ swrlb:greaterThan(?w, 5)
#   ∧ locatedInZone(?n, ?z)
# → hasRiskLevel(?z, ExtremeRisk)

# -----------------------------------------------------------
# KURAL 2 — Yüksek Risk (Bağlamsal)
# İbreli orman + kuraklık + sıcaklık > 38°C + nem < 20%
#   + rüzgar > 8 m/s + duman > 100 PPM → HighRisk
# -----------------------------------------------------------
# SensorNode(?n) ∧ locatedInZone(?n, ?z)
#   ∧ hasForestType(?z, ConiferForest)
#   ∧ hasDroughtIndex(?z, ExtremeDrought)
#   ∧ hasReading(?n, ?r)
#   ∧ temperature(?r, ?t) ∧ swrlb:greaterThan(?t, 38)
#   ∧ humidity(?r, ?h) ∧ swrlb:lessThan(?h, 20)
#   ∧ windSpeedMs(?r, ?w) ∧ swrlb:greaterThan(?w, 8)
#   ∧ smokePPM(?r, ?s) ∧ swrlb:greaterThan(?s, 100)
# → hasRiskLevel(?z, HighRisk)

# -----------------------------------------------------------
# KURAL 3 — Orta Risk
# Sıcaklık > 35°C + nem < 25% + 14 gün yağışsız → ModerateRisk
# -----------------------------------------------------------
# SensorNode(?n) ∧ locatedInZone(?n, ?z)
#   ∧ hasReading(?n, ?r)
#   ∧ temperature(?r, ?t) ∧ swrlb:greaterThan(?t, 35)
#   ∧ humidity(?r, ?h) ∧ swrlb:lessThan(?h, 25)
#   ∧ hasDroughtIndex(?z, ModerateDrought)
# → hasRiskLevel(?z, ModerateRisk)

# -----------------------------------------------------------
# KURAL 4 — Vadi Etkisi Çarpanı
# ModerateRisk + Vadi topoğrafyası + rüzgar > 6 m/s → HighRisk
# -----------------------------------------------------------
# Zone(?z) ∧ hasRiskLevel(?z, ModerateRisk)
#   ∧ hasTopology(?z, ValleyTopology)
#   ∧ SensorNode(?n) ∧ locatedInZone(?n, ?z)
#   ∧ hasReading(?n, ?r)
#   ∧ windSpeedMs(?r, ?w) ∧ swrlb:greaterThan(?w, 6)
# → hasRiskLevel(?z, HighRisk)

# -----------------------------------------------------------
# KURAL 5 — Sensör Anomali Tespiti
# 3 dakikada 15°C'den fazla sıcaklık artışı → SensorFault şüphesi
# (Bu kural backend'de zaman serisi analizi ile desteklenir)
# -----------------------------------------------------------
# SensorNode(?n) ∧ hasReading(?n, ?r1) ∧ hasReading(?n, ?r2)
#   ∧ temperature(?r1, ?t1) ∧ temperature(?r2, ?t2)
#   ∧ swrlb:subtract(?diff, ?t2, ?t1) ∧ swrlb:greaterThan(?diff, 15)
# → hasRiskLevel(pyro:SensorFault, ?n)
