{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "workspaces": ["src/*", "src/types/*", "src/services/*"],
    "include": ["src/**/*"]
}
